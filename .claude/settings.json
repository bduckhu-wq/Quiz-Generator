{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "AI 出题助手项目配置",
  "model": "sonnet",
  "permissions": {
    "allow": [
      "Read:**/*.{md,json,py,js,ts,tsx,jsx,yml,yaml}",
      "Bash:ls",
      "Bash:pwd",
      "Bash:cat",
      "Bash:find",
      "Bash:grep"
    ],
    "deny": [
      "Bash:rm -rf *",
      "Bash:sudo *"
    ]
  },
  "env": {
    "PROJECT_NAME": "AI Quiz Generator",
    "ENVIRONMENT": "development"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '提示：正在修改文件，请确认变更符合 PRD 规范'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '✅ 文件已更新'"
          }
        ]
      }
    ]
  },
  "ignore": [
    "node_modules/**",
    "__pycache__/**",
    "*.pyc",
    ".DS_Store",
    "sessions/**",
    "logs/**",
    "*.log"
  ]
}